<Window x:Class="Login.Painel"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:Login"
        mc:Ignorable="d"
        Title="Painel" Height="450" Width="800">
    <Grid Background="#BFDDF3">
        <StackPanel Width="400" HorizontalAlignment="Left" VerticalAlignment="Center">
            <TextBlock Text="Selecione a estudante:" FontSize="16" TextAlignment="Center" />
            <Border
                CornerRadius="5"
                Background="#fff"
                Margin="0, 10, 0, 10"
                Height="35"
                Width="380">
                <TextBox
                    x:Name="tbEstudanteNome"
                    Background="Transparent"
                    BorderThickness="0"
                    FontSize="16"
                    VerticalAlignment="Center" />
            </Border>
            <Border
                CornerRadius="5"
                Background="#89CFF0"
                Height="35"
                Width="380">
                <Button
                    Content="Buscar imagem"
                    Background="Transparent"
                    BorderThickness="0"
                    Click="BotaoBuscarImagem" />
            </Border>
        </StackPanel>

        <StackPanel Width="400" HorizontalAlignment="Right" VerticalAlignment="Center">
            <Image x:Name="imagemAluna" Width="380"/>
        </StackPanel>
    </Grid>
</Window>
<Window x:Class="Login.Cadastro"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:Login"
        mc:Ignorable="d"
        Title="Cadastro" Height="450" Width="800">
    <Grid Background="#BFDDF3">
        <StackPanel Margin="20" VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock
                Text="Cadastro de usuário"
                FontSize="32"
                TextAlignment="Center" Margin="0, 0, 0, 20" />

            <TextBlock Text="Nome de usuário" />
            <Border
                CornerRadius="5"
                Background="#fff"
                Margin="0, 0, 0, 10"
                Height="35"
                Width="300">
                <TextBox
                    FontSize="16"
                    BorderThickness="0"
                    Background="Transparent"
                    VerticalAlignment="Center"/>
            </Border>

            <TextBlock Text="Senha" />
            <Border
                CornerRadius="5"
                Background="#fff"
                Margin="0, 0, 0, 20"
                Height="35"
                Width="300">
                <TextBox
                    FontSize="16"
                    BorderThickness="0"
                    Background="Transparent"
                    VerticalAlignment="Center"/>
            </Border>

            <Border
                CornerRadius="5"
                Background="#89CFF0"
                Height="35"
                Width="300"
                Margin="0, 0, 0, 10">
                <Button 
                    Content="Fazer cadastro" 
                    Background="Transparent" 
                    BorderThickness="0"/>
                </Border>
        </StackPanel>
    </Grid>
</Window>